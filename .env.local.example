# Copy this file to .env.local and fill in real values.

# --- Supabase ---
# Get these from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...   # service role key (server-only, never expose)

# --- Resend ---
# Get this from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Until you verify a domain on Resend, use the sandbox sender below.
EMAIL_FROM=Laibcove <onboarding@resend.dev>
ADMIN_NOTIFY_EMAIL=laibcove@gmail.com

# --- Admin auth ---
ADMIN_EMAIL=admin@laibcove.com
ADMIN_PASSWORD=change-me-please
# Generate any 32+ char random string. e.g. `openssl rand -base64 48`
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-characters

# --- Payments (manual verification flow) ---
# These numbers are shown to customers on the checkout page. Customers send
# payment manually; the admin then marks the order as Paid in /admin/orders.
JAZZCASH_ACCOUNT_NUMBER=03XXXXXXXXX
JAZZCASH_ACCOUNT_NAME=Laibcove
EASYPAISA_ACCOUNT_NUMBER=03XXXXXXXXX
EASYPAISA_ACCOUNT_NAME=Laibcove

# --- Delivery (NEXT_PUBLIC_ so the cart can show free-delivery progress) ---
# Flat fee in PKR. Set to 0 to make all delivery free.
NEXT_PUBLIC_DELIVERY_PKR=250
# Subtotal threshold (PKR) at which delivery becomes free. 0 disables.
NEXT_PUBLIC_FREE_DELIVERY_THRESHOLD_PKR=5000
